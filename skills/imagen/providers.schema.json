{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/imagen/providers.schema.json",
  "title": "Imagen provider configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["providers"],
  "properties": {
    "$schema": {"type": "string"},
    "default_provider": {"type": "string", "minLength": 1},
    "providers": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {"minLength": 1},
      "additionalProperties": {"$ref": "#/$defs/provider"}
    }
  },
  "$defs": {
    "optionalParams": {
      "type": "string",
      "enum": [
        "size",
        "quality",
        "background",
        "output_format",
        "output_compression",
        "moderation",
        "input_fidelity",
        "aspect_ratio",
        "image_size"
      ]
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "models"],
      "oneOf": [
        {"required": ["api_key_env"], "not": {"required": ["api_key"]}},
        {"required": ["api_key"], "not": {"required": ["api_key_env"]}}
      ],
      "properties": {
        "adapter": {"type": "string", "enum": ["openai_images", "google_generate_content"], "default": "openai_images"},
        "url": {"type": "string", "format": "uri", "pattern": "^https?://"},
        "api_key_env": {"type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"},
        "api_key": {"type": "string", "minLength": 1, "writeOnly": true},
        "default_model": {"type": "string", "minLength": 1},
        "models": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1}
        },
        "timeout": {"type": "number", "exclusiveMinimum": 0},
        "defaults": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "size": {"enum": ["1024x1024", "1536x1024", "1024x1536", "auto"]},
            "quality": {"enum": ["low", "medium", "high", "auto"]},
            "background": {"enum": ["transparent", "opaque", "auto"]},
            "output_format": {"enum": ["png", "jpeg", "jpg", "webp"]},
            "output_compression": {"type": "integer", "minimum": 0, "maximum": 100},
            "moderation": {"type": "string", "minLength": 1},
            "input_fidelity": {"enum": ["low", "high"]},
            "aspect_ratio": {"enum": ["1:1", "1:4", "1:8", "2:3", "3:2", "3:4", "4:1", "4:3", "4:5", "5:4", "8:1", "9:16", "16:9", "21:9"]},
            "image_size": {"enum": ["512", "1K", "2K", "4K"]}
          }
        },
        "supported_params": {
          "type": "array",
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/optionalParams"}
        },
        "extra_headers": {
          "type": "object",
          "propertyNames": {"minLength": 1},
          "additionalProperties": {"type": "string"}
        }
      }
    }
  }
}
